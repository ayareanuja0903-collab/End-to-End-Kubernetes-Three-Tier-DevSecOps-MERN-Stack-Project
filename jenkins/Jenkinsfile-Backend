pipeline {

    agent any

    tools {
        nodejs 'node18'
        sonarQube 'sonar-scanner'
    }

    environment {

        AWS_REGION = "ap-south-1"

        GITHUB_REPO = "https://github.com/ayareanuja0903-collab/End-to-End-Kubernetes-Three-Tier-DevSecOps-MERN-Stack-Project.git"

        ECR_REPOSITORY = "three-tier-dev-backend"

        GITHUB_CREDS = "github-creds"

        AWS_CREDS = "aws-creds"

        SONARQUBE_ENV = "SonarQube"

    }


    options {

        timestamps()

        disableConcurrentBuilds()

        buildDiscarder(logRotator(numToKeepStr: '10'))

    }


    stages {


        stage('Checkout') {

            steps {

                git branch: 'main',
                    credentialsId: "${GITHUB_CREDS}",
                    url: "${GITHUB_REPO}"

            }
        }


        stage('Install Dependencies') {

            steps {

                dir('Application-Code/backend') {

                    sh 'npm install'

                }
            }
        }


        stage('ESLint') {

            steps {

                dir('Application-Code/backend') {

                    sh 'npm run lint || true'

                }
            }
        }


        stage('Unit Tests') {

            steps {

                dir('Application-Code/backend') {

                    sh 'npm test || true'

                }
            }
        }


        stage('SonarQube Analysis') {

            steps {

                dir('Application-Code/backend') {

                    withSonarQubeEnv("${SONARQUBE_ENV}") {

                        sh """

                        sonar-scanner \
                        -Dsonar.projectKey=backend \
                        -Dsonar.projectName=backend \
                        -Dsonar.sources=.

                        """

                    }

                }

            }

        }


        stage('Quality Gate') {

            steps {

                timeout(time: 5, unit: 'MINUTES') {

                    waitForQualityGate abortPipeline: true

                }

            }

        }


        // stage('OWASP Dependency Check') {

        //     steps {

        //         dependencyCheck(
        //             odcInstallation: 'OWASP',
        //             additionalArguments: '--scan Application-Code/backend'
        //         )

        //     }

        // }


        stage('Load AWS Account ID') {

            steps {

                withCredentials([

                    string(
                        credentialsId: 'aws-account-id',
                        variable: 'AWS_ACCOUNT_ID'
                    )

                ]) {

                    script {

                        env.IMAGE_NAME =
                        "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com/${ECR_REPOSITORY}:${BUILD_NUMBER}"

                        echo "IMAGE: ${env.IMAGE_NAME}"

                    }

                }

            }

        }


        stage('Build Docker Image') {

            steps {

                dir('Application-Code/backend') {

                    sh """

                    docker build -t ${IMAGE_NAME} .

                    """

                }

            }

        }


        stage('Trivy Scan') {

            steps {

                sh """

                trivy image --exit-code 0 --severity LOW,MEDIUM ${IMAGE_NAME}

                trivy image --exit-code 1 --severity HIGH,CRITICAL ${IMAGE_NAME}

                """

            }

        }


        stage('Login to AWS ECR') {

            steps {

                withCredentials([

                    [$class: 'AmazonWebServicesCredentialsBinding',
                    credentialsId: "${AWS_CREDS}"],

                    string(
                        credentialsId: 'aws-account-id',
                        variable: 'AWS_ACCOUNT_ID'
                    )

                ]) {

                    sh """

                    aws ecr get-login-password \
                    --region ${AWS_REGION} | \
                    docker login \
                    --username AWS \
                    --password-stdin \
                    ${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com

                    """

                }

            }

        }


        stage('Push Docker Image') {

            steps {

                sh "docker push ${IMAGE_NAME}"

            }

        }


        stage('Update Helm values.yaml') {

            steps {

                sh """

                sed -i 's/tag:.*/tag: "${BUILD_NUMBER}"/' \
                helm-charts/backend/values.yaml

                """

            }

        }


        stage('Commit & Push') {

            steps {

                withCredentials([

                    usernamePassword(
                        credentialsId: "${GITHUB_CREDS}",
                        usernameVariable: 'GIT_USER',
                        passwordVariable: 'GIT_PASS'
                    )

                ]) {

                    sh '''

                    git config user.email "jenkins@devops.com"

                    git config user.name "Jenkins"

                    git add .

                    git commit -m "Backend Image ${BUILD_NUMBER}" || true

                    git push https://${GIT_USER}:${GIT_PASS}@github.com/ayareanuja0903-collab/End-to-End-Kubernetes-Three-Tier-DevSecOps-MERN-Stack-Project.git HEAD:main

                    '''

                }

            }

        }

    }


    post {

        success {

            echo "Backend Pipeline Completed Successfully."

        }


        failure {

            echo "Backend Pipeline Failed."

        }


        always {

            cleanWs()

        }

    }

}
